{
  "name": "magga-mud",
  "version": "0.1.0",
  "private": true,
  "description": "Mutual Understanding Document workspace and static publication site for the PUNNARAJ project.",
  "type": "module",
  "scripts": {
    "build": "npm run build:public && npm run build:developer",
    "build:public": "PUBLICATION_SURFACE=public node scripts/build-site.mjs",
    "build:developer": "PUBLICATION_SURFACE=developer node scripts/build-site.mjs",
    "dev": "PUBLICATION_SURFACE=public node scripts/build-site.mjs --watch",
    "serve": "python3 -m http.server 4173 -d dist-public",
    "serve:developer": "python3 -m http.server 4174 -d dist-developer",
    "check": "node scripts/check-site.mjs && node scripts/check-release.mjs",
    "check:release": "node scripts/check-release.mjs"
  },
  "keywords": [
    "mud",
    "mutual-understanding-document",
    "obsidian",
    "markdown",
    "punnaraj",
    "github-pages",
    "cloudflare-pages"
  ],
  "license": "UNLICENSED"
}
